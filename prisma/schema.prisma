generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Standort {
  id                 String             @id @default(cuid())
  name               String
  adresse            String
  sitzplaetze        Int
  hatTerrasse        Boolean
  hatGrill           Boolean
  aktiv              Boolean            @default(true)
  tische             Tisch[]
  reservierungen     Reservierung[]
  tischKombinationen TischKombination[]
  mitarbeiter        Mitarbeiter[]
  artikelAngebote    ArtikelStandort[]
  bestellungen       Bestellung[]
}

model Artikel {
  id                String            @id @default(cuid())
  name              String
  kategorie         String
  preisCent         Int
  benoetigtGrill    Boolean           @default(false)
  aktiv             Boolean           @default(true)
  standortAngebote  ArtikelStandort[]
  bestellpositionen Bestellposition[]
}

model ArtikelStandort {
  artikelId  String
  standortId String
  artikel    Artikel  @relation(fields: [artikelId], references: [id], onDelete: Restrict)
  standort   Standort @relation(fields: [standortId], references: [id], onDelete: Restrict)

  @@id([artikelId, standortId])
  @@index([standortId])
}

model Mitarbeiter {
  id                   String                        @id @default(cuid())
  name                 String
  benutzername         String                        @unique
  rolle                String
  hauptstandortId      String
  aktiv                Boolean                       @default(true)
  hauptstandort        Standort                      @relation(fields: [hauptstandortId], references: [id], onDelete: Restrict)
  bestellungen         Bestellung[]
  storniertePositionen Bestellposition[]             @relation("BestellpositionStorno")
  authentifizierung    MitarbeiterAuthentifizierung?
  sitzungen            MitarbeiterSitzung[]

  @@index([hauptstandortId])
}

model MitarbeiterAuthentifizierung {
  mitarbeiterId  String      @id
  passwortHash   String
  aktualisiertAm DateTime    @updatedAt
  mitarbeiter    Mitarbeiter @relation(fields: [mitarbeiterId], references: [id], onDelete: Cascade)
}

model MitarbeiterSitzung {
  id            String      @id @default(cuid())
  tokenHash     String      @unique
  mitarbeiterId String
  gueltigBis    DateTime
  erstelltAm    DateTime    @default(now())
  mitarbeiter   Mitarbeiter @relation(fields: [mitarbeiterId], references: [id], onDelete: Cascade)

  @@index([mitarbeiterId])
  @@index([gueltigBis])
}

model Tisch {
  id             String                  @id @default(cuid())
  standortId     String
  nummer         String
  kapazitaet     Int
  bereich        String
  kombinierbar   Boolean                 @default(false)
  aktiv          Boolean                 @default(true)
  standort       Standort                @relation(fields: [standortId], references: [id], onDelete: Restrict)
  reservierungen ReservierungTisch[]
  belegungen     Belegung[]
  kombinationen  TischKombinationTisch[]
  bestellungen   Bestellung[]

  @@unique([standortId, nummer])
  @@index([standortId])
}

model TischKombination {
  id         String                  @id @default(cuid())
  standortId String
  schluessel String                  @unique
  standort   Standort                @relation(fields: [standortId], references: [id], onDelete: Restrict)
  tische     TischKombinationTisch[]

  @@index([standortId])
}

model TischKombinationTisch {
  kombinationId String
  tischId       String
  kombination   TischKombination @relation(fields: [kombinationId], references: [id], onDelete: Cascade)
  tisch         Tisch            @relation(fields: [tischId], references: [id], onDelete: Restrict)

  @@id([kombinationId, tischId])
  @@index([tischId])
}

model Gast {
  id             String         @id @default(cuid())
  name           String
  telefon        String
  notiz          String
  istStammgast   Boolean        @default(false)
  hatBellaCard   Boolean        @default(false)
  besuchsanzahl  Int            @default(0)
  aktiv          Boolean        @default(true)
  reservierungen Reservierung[]
}

model Reservierung {
  id                       String              @id @default(cuid())
  gastId                   String
  standortId               String
  beginn                   DateTime
  ende                     DateTime
  personenanzahl           Int
  status                   String
  typ                      String              @default("reservierung")
  notiz                    String
  istGruppe                Boolean             @default(false)
  erstelltVonMitarbeiterId String
  gast                     Gast                @relation(fields: [gastId], references: [id], onDelete: Restrict)
  standort                 Standort            @relation(fields: [standortId], references: [id], onDelete: Restrict)
  tische                   ReservierungTisch[]
  belegungen               Belegung[]
  bestellungen             Bestellung[]

  @@index([gastId])
  @@index([standortId])
  @@index([beginn, ende])
}

model Bestellung {
  id                          String            @id @default(cuid())
  standortId                  String
  tischId                     String
  reservierungId              String?
  aufgenommenVonMitarbeiterId String
  status                      String            @default("offen")
  erstelltAm                  DateTime          @default(now())
  standort                    Standort          @relation(fields: [standortId], references: [id], onDelete: Restrict)
  tisch                       Tisch             @relation(fields: [tischId], references: [id], onDelete: Restrict)
  reservierung                Reservierung?     @relation(fields: [reservierungId], references: [id], onDelete: Restrict)
  aufgenommenVonMitarbeiter   Mitarbeiter       @relation(fields: [aufgenommenVonMitarbeiterId], references: [id], onDelete: Restrict)
  positionen                  Bestellposition[]

  @@index([standortId])
  @@index([tischId])
  @@index([reservierungId])
  @@index([aufgenommenVonMitarbeiterId])
}

model Bestellposition {
  id                        String       @id @default(cuid())
  bestellungId              String
  artikelId                 String
  menge                     Int
  einzelpreisCent           Int
  sonderwunsch              String
  status                    String       @default("offen")
  storniertAm               DateTime?
  storniertVonMitarbeiterId String?
  bestellung                Bestellung   @relation(fields: [bestellungId], references: [id], onDelete: Restrict)
  artikel                   Artikel      @relation(fields: [artikelId], references: [id], onDelete: Restrict)
  storniertVonMitarbeiter   Mitarbeiter? @relation("BestellpositionStorno", fields: [storniertVonMitarbeiterId], references: [id], onDelete: Restrict)

  @@index([bestellungId])
  @@index([artikelId])
  @@index([storniertVonMitarbeiterId])
}

model Belegung {
  id             String       @id @default(cuid())
  tischId        String
  reservierungId String
  beginn         DateTime     @default(now())
  ende           DateTime?
  tisch          Tisch        @relation(fields: [tischId], references: [id], onDelete: Restrict)
  reservierung   Reservierung @relation(fields: [reservierungId], references: [id], onDelete: Restrict)

  @@index([tischId, ende])
  @@index([reservierungId])
}

model ReservierungTisch {
  reservierungId String
  tischId        String
  reservierung   Reservierung @relation(fields: [reservierungId], references: [id], onDelete: Cascade)
  tisch          Tisch        @relation(fields: [tischId], references: [id], onDelete: Restrict)

  @@id([reservierungId, tischId])
  @@index([tischId])
}
