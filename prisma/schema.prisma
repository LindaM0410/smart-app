generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Standort {
  id             String         @id @default(cuid())
  name           String
  adresse        String
  sitzplaetze    Int
  hatTerrasse    Boolean
  hatGrill       Boolean
  aktiv          Boolean        @default(true)
  tische         Tisch[]
  reservierungen Reservierung[]
  tischKombinationen TischKombination[]
}

model Tisch {
  id             String              @id @default(cuid())
  standortId     String
  nummer         String
  kapazitaet     Int
  bereich        String
  kombinierbar   Boolean             @default(false)
  aktiv          Boolean             @default(true)
  standort       Standort            @relation(fields: [standortId], references: [id], onDelete: Restrict)
  reservierungen ReservierungTisch[]
  belegungen     Belegung[]
  kombinationen  TischKombinationTisch[]

  @@unique([standortId, nummer])
  @@index([standortId])
}

model TischKombination {
  id          String                   @id @default(cuid())
  standortId  String
  schluessel  String                   @unique
  standort    Standort                 @relation(fields: [standortId], references: [id], onDelete: Restrict)
  tische      TischKombinationTisch[]

  @@index([standortId])
}

model TischKombinationTisch {
  kombinationId String
  tischId       String
  kombination   TischKombination @relation(fields: [kombinationId], references: [id], onDelete: Cascade)
  tisch         Tisch             @relation(fields: [tischId], references: [id], onDelete: Restrict)

  @@id([kombinationId, tischId])
  @@index([tischId])
}

model Gast {
  id             String         @id @default(cuid())
  name           String
  telefon        String
  notiz          String
  istStammgast   Boolean        @default(false)
  hatBellaCard   Boolean        @default(false)
  besuchsanzahl  Int            @default(0)
  aktiv          Boolean        @default(true)
  reservierungen Reservierung[]
}

model Reservierung {
  id                       String              @id @default(cuid())
  gastId                   String
  standortId               String
  beginn                   DateTime
  ende                     DateTime
  personenanzahl           Int
  status                   String
  typ                      String              @default("reservierung")
  notiz                    String
  istGruppe                Boolean             @default(false)
  erstelltVonMitarbeiterId String
  gast                     Gast                @relation(fields: [gastId], references: [id], onDelete: Restrict)
  standort                 Standort            @relation(fields: [standortId], references: [id], onDelete: Restrict)
  tische                   ReservierungTisch[]
  belegungen               Belegung[]

  @@index([gastId])
  @@index([standortId])
  @@index([beginn, ende])
}

model Belegung {
  id              String        @id @default(cuid())
  tischId         String
  reservierungId  String
  beginn          DateTime      @default(now())
  ende            DateTime?
  tisch           Tisch         @relation(fields: [tischId], references: [id], onDelete: Restrict)
  reservierung    Reservierung  @relation(fields: [reservierungId], references: [id], onDelete: Restrict)

  @@index([tischId, ende])
  @@index([reservierungId])
}

model ReservierungTisch {
  reservierungId String
  tischId        String
  reservierung   Reservierung @relation(fields: [reservierungId], references: [id], onDelete: Cascade)
  tisch          Tisch        @relation(fields: [tischId], references: [id], onDelete: Restrict)

  @@id([reservierungId, tischId])
  @@index([tischId])
}
